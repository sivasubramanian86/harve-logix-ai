{
  "name": "harvelogix-mobile",
  "version": "1.0.0",
  "description": "HarveLogix AI - Farmer Mobile App",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace HarveLogix.xcworkspace -scheme HarveLogix -configuration Release",
    "deploy:android": "cd android && ./gradlew bundleRelease",
    "deploy:ios": "cd ios && xcodebuild -workspace HarveLogix.xcworkspace -scheme HarveLogix -configuration Release -archivePath HarveLogix.xcarchive archive"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-native": "^0.72.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/stack": "^6.3.0",
    "react-native-screens": "^3.25.0",
    "react-native-safe-area-context": "^4.7.0",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-reanimated": "^3.5.0",
    "@react-native-async-storage/async-storage": "^1.21.0",
    "react-native-sqlite-storage": "^6.0.0",
    "aws-amplify": "^6.0.0",
    "@aws-amplify/react-native": "^1.0.0",
    "amazon-cognito-identity-js": "^6.2.0",
    "aws-sdk": "^2.1500.0",
    "axios": "^1.6.0",
    "react-native-vector-icons": "^10.0.0",
    "react-native-image-picker": "^7.0.0",
    "react-native-camera": "^4.2.0",
    "react-native-maps": "^1.7.0",
    "react-native-geolocation-service": "^5.3.0",
    "react-native-push-notification": "^8.1.0",
    "react-native-webview": "^13.6.0",
    "react-native-linear-gradient": "^2.8.0",
    "react-native-svg": "^14.0.0",
    "react-native-chart-kit": "^6.12.0",
    "react-native-date-picker": "^4.8.0",
    "react-native-modal": "^13.0.0",
    "react-native-toast-message": "^2.1.0",
    "react-native-loading-spinner-overlay": "^3.0.0",
    "redux": "^4.2.0",
    "react-redux": "^8.1.0",
    "redux-thunk": "^2.4.0",
    "redux-persist": "^6.0.0",
    "i18next": "^23.7.0",
    "react-i18next": "^13.5.0",
    "moment": "^2.29.0",
    "lodash": "^4.17.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",
    "@react-native/babel-preset": "^0.73.0",
    "@react-native/eslint-config": "^0.73.0",
    "@react-native/metro-config": "^0.73.0",
    "@testing-library/react-native": "^12.4.0",
    "@testing-library/jest-native": "^5.4.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "metro": "^0.80.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.d.ts",
      "!src/index.{js,ts}",
      "!src/**/*.stories.{js,ts}"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "arrowParens": "always"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native",
      "prettier"
    ],
    "rules": {
      "prettier/prettier": "error",
      "react-native/no-unused-styles": "warn",
      "react-native/no-inline-styles": "warn"
    }
  }
}
