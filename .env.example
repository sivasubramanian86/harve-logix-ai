# HarveLogix AI - Environment Configuration Example
# Copy this file to .env and fill in your actual values

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Environment
ENVIRONMENT=dev
DEBUG=true

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_REGION=ap-south-1

# DynamoDB Configuration
DYNAMODB_REGION=ap-south-1
DYNAMODB_ENDPOINT=http://localhost:8000  # For local development
DYNAMODB_FARMERS_TABLE=harvelogix-farmers-dev
DYNAMODB_DECISIONS_TABLE=harvelogix-agent-decisions-dev
DYNAMODB_PROCESSORS_TABLE=harvelogix-processor-profiles-dev
DYNAMODB_STORAGE_TEMPLATES_TABLE=harvelogix-storage-templates-dev

# RDS Configuration
RDS_HOST=your-rds-endpoint.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=harvelogix
RDS_USERNAME=admin
RDS_PASSWORD=your_password_here
RDS_REGION=ap-south-1

# S3 Configuration
S3_MODELS_BUCKET=harvelogix-models-dev-123456789
S3_IMAGES_BUCKET=harvelogix-images-dev-123456789
S3_REGION=ap-south-1

# Redshift Configuration
REDSHIFT_HOST=your-redshift-endpoint.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=harvelogix
REDSHIFT_USERNAME=admin
REDSHIFT_PASSWORD=your_password_here

# Cognito Configuration
COGNITO_USER_POOL_ID=ap-south-1_xxxxxxxxx
COGNITO_CLIENT_ID=your_client_id_here
COGNITO_REGION=ap-south-1

# EventBridge Configuration
EVENTBRIDGE_BUS_NAME=harvelogix-events-dev
EVENTBRIDGE_REGION=ap-south-1

# External APIs
WEATHER_API_KEY=your_weather_api_key_here
WEATHER_API_URL=https://api.openweathermap.org/data/2.5
ENAM_API_URL=https://api.enam.gov.in
RAZORPAY_KEY_ID=your_razorpay_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Lambda Configuration
LAMBDA_TIMEOUT=60
LAMBDA_MEMORY=512
LAMBDA_REGION=ap-south-1

# API Gateway Configuration
API_GATEWAY_STAGE=dev
API_GATEWAY_REGION=ap-south-1
API_RATE_LIMIT=100

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
CLOUDWATCH_LOG_GROUP=/aws/lambda/harvelogix-dev

# Performance Configuration
RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=2
RETRY_BACKOFF_MULTIPLIER=2.0
REQUEST_TIMEOUT_SECONDS=30

# Feature Flags
ENABLE_BEDROCK=true
ENABLE_REKOGNITION=true
ENABLE_EVENTBRIDGE=true
ENABLE_OFFLINE_MODE=true

# Income Impact Defaults (in rupees)
HARVEST_READY_INCOME_IMPACT=4500
STORAGE_SCOUT_INCOME_IMPACT=7500
SUPPLY_MATCH_INCOME_IMPACT=20000
WATER_WISE_INCOME_IMPACT=8000
QUALITY_HUB_INCOME_IMPACT=5000
COLLECTIVE_VOICE_INCOME_IMPACT=3000

# Mobile App Configuration
MOBILE_APP_NAME=HarveLogix
MOBILE_APP_VERSION=1.0.0
MOBILE_API_BASE_URL=https://api.harvelogix.ai/v1
MOBILE_OFFLINE_SYNC_INTERVAL=300

# Web Dashboard Configuration
WEB_APP_NAME=HarveLogix Dashboard
WEB_APP_VERSION=1.0.0
WEB_API_BASE_URL=https://api.harvelogix.ai/v1
WEB_REFRESH_INTERVAL=5000

# Database Backup Configuration
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30

# Monitoring Configuration
MONITORING_ENABLED=true
CLOUDWATCH_ENABLED=true
QUICKSIGHT_ENABLED=true

# Security Configuration
ENCRYPTION_ENABLED=true
KMS_KEY_ID=arn:aws:kms:ap-south-1:123456789:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TLS_ENABLED=true
TLS_VERSION=1.3
