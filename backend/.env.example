# HarveLogixAI Backend Environment Configuration
# Copy to .env.local for local development
# Or export these vars before running: export AWS_REGION=ap-south-2

# AWS Configuration
AWS_REGION=ap-south-2
BEDROCK_MODEL_ID=arn:aws:bedrock:ap-south-2:020513638290:application-inference-profile/3uca3qqdrcyo

# Bedrock Parameters
BEDROCK_MAX_TOKENS=1024
BEDROCK_TEMPERATURE=0.7

# Database
RDS_HOST=localhost
RDS_PORT=5432
RDS_DATABASE=harvelogix
RDS_USER=postgres
RDS_PASSWORD=

# DynamoDB Tables (if using)
FARMERS_TABLE=farmers
AGENT_DECISIONS_TABLE=agent_decisions
PROCESSOR_PROFILES_TABLE=processor_profiles
STORAGE_TEMPLATES_TABLE=storage_templates

# External APIs
WEATHER_API_KEY=your_key_here
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

# EventBridge
EVENTBRIDGE_BUS_NAME=harvelogix-events

# Performance
LAMBDA_TIMEOUT_SECONDS=30

# Retry Policy
MAX_RETRIES=3
RETRY_DELAY_SECONDS=1

# Logging
LOG_LEVEL=INFO

# Node.js
NODE_ENV=development
PORT=3000
