# HarveLogix AI - Development Environment Configuration
# Copy this file to .env.development and fill in your values

ENVIRONMENT=dev
DEBUG=true
LOG_LEVEL=DEBUG

# Local Development
DYNAMODB_ENDPOINT=http://localhost:8000
RDS_HOST=localhost
RDS_PORT=5432
RDS_PASSWORD=password

# Disable external services for local testing
ENABLE_BEDROCK=false
ENABLE_REKOGNITION=false
ENABLE_EVENTBRIDGE=false

# Use mock data
USE_MOCK_DATA=true
MOCK_DATA_PATH=./backend/tests/fixtures/mock_data

# Local API
API_BASE_URL=http://localhost:8000
API_PORT=8000

# Disable rate limiting for development
API_RATE_LIMIT=1000

# Shorter timeouts for development
REQUEST_TIMEOUT_SECONDS=10
RETRY_ATTEMPTS=1
